# ---- Database (PostgreSQL) ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/support_analyzer

# ---- Redis (BullMQ queue) ----
REDIS_URL=redis://localhost:6379

# ---- Object storage (MinIO / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bundles

# ---- Upload (tus) ----
TUS_PORT=1080
MAX_UPLOAD_BYTES=8589934592
CORS_ORIGINS=http://localhost:3000
# Public URL the browser uploads to (Uppy/tus):
NEXT_PUBLIC_TUS_URL=http://localhost:1080/files

# ---- LLM (Gemini via Vercel AI SDK) ----
GOOGLE_GENERATIVE_AI_API_KEY=
LLM_MODEL=gemini-1.5-pro

# ---- RAG (Lexiro) — optional ----
# When unset, the pipeline still runs (rules + LLM) without knowledge-base sources.
LEXIRO_API_URL=
LEXIRO_API_KEY=

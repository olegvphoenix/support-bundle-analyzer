# Production .env for docker-compose.prod.yml (isolated stack on a shared host).
# Internal service hostnames match compose service names.

DATABASE_URL=postgres://postgres:postgres@postgres:5432/support_analyzer
REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bundles

# Loopback host ports — published only to 127.0.0.1 and fronted by host nginx.
WEB_PORT=8090
TUS_HOST_PORT=1080
TUS_PORT=1080
MAX_UPLOAD_BYTES=8589934592

# Path-based hosting behind nginx at http://<host>/sba/ (no DNS needed).
BASE_PATH=/sba
NEXT_PUBLIC_BASE_PATH=/sba
TUS_PATH=/sba/files

# Public-facing URLs (browser hits these via nginx on port 80).
NEXT_PUBLIC_TUS_URL=http://89.167.61.115/sba/files
CORS_ORIGINS=http://89.167.61.115

# LLM (optional — without it the pipeline runs rules-only).
GOOGLE_GENERATIVE_AI_API_KEY=
LLM_MODEL=gemini-1.5-pro

# RAG Lexiro (optional).
LEXIRO_API_URL=
LEXIRO_API_KEY=
